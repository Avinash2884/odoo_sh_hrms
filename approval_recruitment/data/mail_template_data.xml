<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="mail_template_resignation_initiation" model="mail.template">
            <field name="name">Resignation Initiation Mail</field>
            <field name="model_id" ref="approval_recruitment.model_initiate_separation"/>
            <field name="email_from">{{ object.employee_id.work_email }}</field>
            <field name="email_to">{{ object.reporting_manager_id.work_email }}</field>
            <field name="subject">Resignation Initiated - {{ object.employee_id.name }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; font-size:13px; color:#333; line-height:1.5;">

                    <p>
                        Dear <t t-out="object.reporting_manager_id.name"/>,
                    </p>

                    <p>
                        This is to inform you that
                        <b><t t-out="object.employee_id.name"/></b>
                        (<t t-out="object.ls_employee_id"/>) has initiated a resignation request.
                    </p>

                    <p>
                        <b>Resignation Date:</b> <t t-out="format_date(object.create_date)"/><br/>
                        <b>Reason for Resignation:</b> <t t-out="dict(object._fields['resignation_reason'].selection).get(object.resignation_reason)"/>
                        <!-- Show detailed reason if 'Other' is selected -->
                        <t t-if="object.resignation_reason == 'other'">
                            : <t t-out="object.detailed_reason"/>
                        </t>
                    </p>

                    <p>
                        Kindly review and approve the request in the system to proceed further.
                    </p>
                    <p>
                        Regards,<br/>
                        <t t-out="user.name"/>
                    </p>

                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
        <record id="mail_template_manager_approval" model="mail.template">
            <field name="name">Resignation Manager Approval - Approved</field>
            <field name="model_id" ref="approval_recruitment.model_initiate_separation"/>
            <field name="email_from">{{ object.reporting_manager_id.work_email }}</field>
            <field name="email_to">{{ object.hr_id.work_email }}</field>
            <field name="email_cc">{{ object.hr_head_id.work_email }}</field>
            <field name="subject">Resignation Approved by Reporting Manager – {{ object.employee_id.name }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; font-size:13px; color:#333; line-height:1.5;">

                    <p>Dear Team,</p>

                    <p>
                        The resignation request submitted by
                        <b><t t-out="object.employee_id.name"/></b>
                        (<t t-out="object.ls_employee_id"/>) has been approved by the Reporting Manager.
                    </p>

                    <p>
                        Kindly review the request, confirm the Last Working Day as per policy, and proceed with further approvals.
                    </p>

                    <p>
                        Regards,<br/>
                        <t t-out="object.reporting_manager_id.name"/>
                    </p>

                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
        <record id="mail_template_manager_reject" model="mail.template">
            <field name="name">Resignation Manager Approval - Rejected</field>
            <field name="model_id" ref="approval_recruitment.model_initiate_separation"/>
            <field name="email_from">{{ object.reporting_manager_id.work_email }}</field>
            <field name="email_to">{{ object.hr_id.work_email }}</field>
            <field name="email_cc">{{ object.hr_head_id.work_email }}</field>
            <field name="subject">Resignation Rejected by Reporting Manager – {{ object.employee_id.name }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; font-size:13px; color:#333; line-height:1.5;">

                    <p>Dear Team,</p>

                    <p>
                        The resignation request submitted by
                        <b><t t-out="object.employee_id.name"/></b>
                        (<t t-out="object.ls_employee_id"/>) has been rejected by the Reporting Manager.
                    </p>

                    <p>
                        Kindly review the request and take necessary follow-up action.
                    </p>

                    <p>
                        Regards,<br/>
                        <t t-out="object.reporting_manager_id.name"/>
                    </p>

                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
        <record id="mail_template_hr_approval" model="mail.template">
            <field name="name">HR Approval - Initiate Handover</field>
            <field name="model_id" ref="approval_recruitment.model_initiate_separation"/>
            <field name="email_from">{{ object.hr_head_id.work_email }}</field>
            <field name="email_to">{{ object.employee_id.work_email }}</field>
            <field name="subject">Resignation Initiation Approved – Initiate Handover Responsibilities</field>

            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; font-size:13px; color:#333; line-height:1.5;">

                    <p>
                        Dear <t t-out="object.employee_id.name"/>,
                    </p>

                    <p>
                        Your resignation has been approved.
                    </p>

                    <p>
                        <b>Confirmed Last Working Day:</b>
                        <t t-out="format_date(object.last_working_date)"/>
                    </p>

                    <p>
                        You are requested to complete the Handing Over Responsibilities Form in the HR system
                        within the stipulated timeline to ensure a smooth transition.
                    </p>

                    <p>
                        For any clarification, please reach out to HR@lifesigns.us.
                    </p>

                    <p>
                        Regards,<br/>
                        <t t-out="object.hr_head_id.name"/>
                    </p>

                </div>
            </field>
        </record>
        <record id="mail_template_hr_reject" model="mail.template">
            <field name="name">HR Rejection Mail</field>
            <field name="model_id" ref="approval_recruitment.model_initiate_separation"/>
            <field name="email_from">{{ object.hr_head_id.work_email }}</field>
            <field name="email_to">{{ object.employee_id.work_email }}</field>
            <field name="subject">Resignation Request Rejected</field>

            <field name="body_html" type="html">

