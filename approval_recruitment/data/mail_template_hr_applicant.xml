<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="mail_template_offer_letter_release_notification" model="mail.template">
            <field name="name">Offer Letter : Release Notification</field>
            <field name="model_id" ref="hr_contract_salary.model_hr_contract_salary_offer"/>
            <field name="subject">{{ object.company_id.name }}: Job Offer</field>
            <field name="partner_to" eval="False"/>
            <field name="email_to" eval="False"/>
            <field name="use_default_to" eval="True"/>
            <field name="description">Sent manually when you generate a simulation link on the employee contract</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <h3 style="text-align: center; text-decoration: underline; margin-bottom: 20px;">
                        <strong>Offer Letter</strong>
                    </h3>
                    <p>Dear <t t-out="object.applicant_id.partner_name"/>,</p>
                    <p>We are pleased to inform you that you have been selected for the <strong><t t-out="object.applicant_id.job_id.name"/></strong> at <strong><t t-out="object.company_id.name"/></strong></p>
                    <p>
                        Your offer letter has been shared with you through our system. Please review the details and complete the required actions by <b>Offer Acceptance Deadline.</b>
                    </p>
                    <p>
                        If you have any questions regarding the offer, you may reach out using the contact details provided in the portal.
                    </p>

                    <p>
                        We look forward to your response.
                    </p>
                </div>
                <p>
                    Regards,<br/>
                    <t t-out="user.name"/><br></br>
                    <t t-out="user.company_id.name"/>
                </p>
            </field>
            <field name="lang">{{ object.employee_version_id.employee_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>


    </data>
</odoo>

