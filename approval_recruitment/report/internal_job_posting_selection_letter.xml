<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Report Action -->
    <record id="action_internal_job_posting_selection_letter" model="ir.actions.report">
        <field name="name">Internal Job Posting Selection Letter</field>
        <field name="model">hr.employee</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">approval_recruitment.template_internal_job_posting_selection_letter</field>
        <field name="report_file">approval_recruitment.template_internal_job_posting_selection_letter</field>
        <field name="print_report_name">'Internal Job Posting Selection Letter'</field>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Template -->
    <template id="template_internal_job_posting_selection_letter">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="object">
                <t t-call="web.external_layout">

                    <div style="margin: 30px; font-family: Arial, sans-serif; font-size: 14px; line-height: 1.8;">

                        <h3 style="text-align: center; text-decoration: underline; margin-bottom: 30px;">
                            Internal Job Posting Selection Letter
                        </h3>

                         <p style="text-align:right; margin-bottom: 25px;">
                            Date: <t t-esc="time.strftime('%d-%m-%Y')"/>
                        </p>

                        <p style="margin: 2px 0; line-height: 1.5;">
                            Name: <t t-esc="object.name"/>
                        </p>

                        <p style="margin: 2px 0; line-height: 1.5;">
                            Employee Code: <t t-esc="object.ls_employee_id"/>
                        </p>
                        <p style="margin-top: 20px;">
                            Dear, <t t-esc="object.name"/>
                        </p>
                        <p>
                            We are pleased to inform you that your application for the Internal Job Posting (IJP) for the role of <t t-esc="object.ls_designation_id.name"/> in the <strong><t t-esc="object.department_id.name"/></strong> Department has been approved.
                        </p>
                        <p>
                            Your effective date of movement to the new role will be , and you will be reporting to <strong><t t-esc="object.parent_id.name"/></strong>.
                        </p>
                        <p>
                            We believe your experience, skills, and commitment will make a positive impact in this new role and contribute meaningfully to the team’s success.
                        </p>
                        <p>
                            You are requested to complete the following prior to transition:
                            <ul>
                                <li>
                                    Handover of current responsibilities to your existing team
                                </li>
                                <li>
                                    Coordination with your new reporting manager for taking over the new role
                                </li>
                            </ul>
                        </p>
                        <p>
                            All other terms and conditions of your employment remain unchanged.
                        </p>
                        <p>
                            We congratulate you on this new opportunity and look forward to your continued growth and success at Lifesigns.
                        </p>
                        <p style="margin-top: 40px;">
                            For <t t-esc="object.company_id.name"/>
                        </p>
                        <br></br>

                        <p style="margin: 2px 0; line-height: 1.5;">Koushalya R</p>
                        <p style="margin: 2px 0; line-height: 1.5;">Head – Human Resources </p>

                    </div>

                </t>
            </t>
        </t>
    </template>

</odoo>