<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ========================= -->
    <!-- List View -->
    <!-- ========================= -->
    <record id="view_account_office_name_list" model="ir.ui.view">
        <field name="name">account.office.name.list</field>
        <field name="model">account.office.name</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Form View -->
    <!-- ========================= -->
    <record id="view_account_office_name_form" model="ir.ui.view">
        <field name="name">account.office.name.form</field>
        <field name="model">account.office.name</field>
        <field name="arch" type="xml">
            <form string="Account Office Name">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Action -->
    <!-- ========================= -->
    <record id="action_account_office_name" model="ir.actions.act_window">
        <field name="name">Account Office Names</field>
        <field name="res_model">account.office.name</field>
        <field name="view_mode">list,form</field>
    </record>



</odoo>
