<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    
    <record id="view_employment_type_list" model="ir.ui.view">
        <field name="name">employment.type.list</field>
        <field name="model">employment.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
    
    <record id="view_employment_type_form" model="ir.ui.view">
        <field name="name">employment.type.form</field>
        <field name="model">employment.type</field>
        <field name="arch" type="xml">
            <form string="Employment Type">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_employment_type" model="ir.actions.act_window">
        <field name="name">Employment Types</field>
        <field name="res_model">employment.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
