<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_function_list" model="ir.ui.view">
        <field name="name">function.list</field>
        <field name="model">function</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_function_form" model="ir.ui.view">
        <field name="name">function.form</field>
        <field name="model">function</field>
        <field name="arch" type="xml">
            <form string="Function">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_function" model="ir.actions.act_window">
        <field name="name">Functions</field>
        <field name="res_model">function</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
