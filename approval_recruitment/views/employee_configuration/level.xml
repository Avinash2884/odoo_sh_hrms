<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_level_list" model="ir.ui.view">
        <field name="name">level.list</field>
        <field name="model">level</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_level_form" model="ir.ui.view">
        <field name="name">level.form</field>
        <field name="model">level</field>
        <field name="arch" type="xml">
            <form string="Level">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_level" model="ir.actions.act_window">
        <field name="name">Levels</field>
        <field name="res_model">level</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
