<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_parent_account_list" model="ir.ui.view">
        <field name="name">parent.account.list</field>
        <field name="model">parent.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_parent_account_form" model="ir.ui.view">
        <field name="name">parent.account.form</field>
        <field name="model">parent.account</field>
        <field name="arch" type="xml">
            <form string="Parent Account">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_parent_account" model="ir.actions.act_window">
        <field name="name">Parent Accounts</field>
        <field name="res_model">parent.account</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
