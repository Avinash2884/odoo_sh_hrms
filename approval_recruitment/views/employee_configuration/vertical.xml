<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="view_vertical_list" model="ir.ui.view">
        <field name="name">vertical.list</field>
        <field name="model">vertical</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_vertical_form" model="ir.ui.view">
        <field name="name">vertical.form</field>
        <field name="model">vertical</field>
        <field name="arch" type="xml">
            <form string="Vertical">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_vertical" model="ir.actions.act_window">
        <field name="name">Verticals</field>
        <field name="res_model">vertical</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
