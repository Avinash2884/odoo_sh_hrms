<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="view_ls_state_public_holiday_list" model="ir.ui.view">
    <field name="name">ls.state.public.holiday.list</field>
    <field name="model">ls.state.public.holiday</field>
    <field name="arch" type="xml">
        <list string="State Public Holidays">
            <field name="state_id"/>
        </list>
    </field>
</record>

<!-- FORM VIEW -->
<record id="view_ls_state_public_holiday_form" model="ir.ui.view">
    <field name="name">ls.state.public.holiday.form</field>
    <field name="model">ls.state.public.holiday</field>
    <field name="arch" type="xml">
        <form string="State Public Holiday">
            <sheet>
                <group>
                    <field name="state_id"/>
                </group>

                <notebook>
                    <page string="Public Holidays">
                        <field name="holiday_line_ids">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="date"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>
<record id="action_ls_state_public_holiday" model="ir.actions.act_window">
    <field name="name">State Public Holidays</field>
    <field name="res_model">ls.state.public.holiday</field>
    <field name="view_mode">list,form</field>
</record>

    <menuitem id="menu_ls_state_public_holiday"
                name="State Public Holidays"
                parent="hr.menu_human_resources_configuration"
                action="action_ls_state_public_holiday"
                sequence="-1"/>

</odoo>