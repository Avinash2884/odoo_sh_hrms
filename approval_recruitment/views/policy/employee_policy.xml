<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_employee_policy_list" model="ir.ui.view">
        <field name="name">employee.policy.list</field>
        <field name="model">employee.policy</field>
        <field name="arch" type="xml">
            <list string="Policies">
                <field name="name"/>
            </list>
        </field>
    </record>


    <record id="view_employee_policy_form" model="ir.ui.view">
        <field name="name">employee.policy.form</field>
        <field name="model">employee.policy</field>
        <field name="arch" type="xml">
            <form string="Policy">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="document" filename="file_name" widget="pdf_viewer" readonly="1" string=""/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_employee_policy" model="ir.actions.act_window">
        <field name="name">Company Policies</field>
        <field name="res_model">employee.policy</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>