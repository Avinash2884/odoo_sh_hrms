<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Question list View -->
    <record id="view_exit_interview_question_list" model="ir.ui.view">
        <field name="name">exit.interview.question.list</field>
        <field name="model">exit.interview.question</field>
        <field name="arch" type="xml">
            <list string="Exit Interview Questions">
                <field name="name"/>
                <field name="sequence" widget="handle"/>
            </list>
        </field>
    </record>

    <!-- Question Form View -->
    <record id="view_exit_interview_question_form" model="ir.ui.view">
        <field name="name">exit.interview.question.form</field>
        <field name="model">exit.interview.question</field>
        <field name="arch" type="xml">
            <form string="Exit Interview Question">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                    </group>
                    <notebook>
                        <page string="Options">
                            <field name="option_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="sequence" widget="handle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_exit_interview_question" model="ir.actions.act_window">
        <field name="name">Exit Interview Questions</field>
        <field name="res_model">exit.interview.question</field>
        <field name="view_mode">list,form</field>
    </record>



</odoo>