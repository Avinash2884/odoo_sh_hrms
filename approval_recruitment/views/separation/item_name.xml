<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- list View -->
    <record id="view_item_name_list" model="ir.ui.view">
        <field name="name">item.name.list</field>
        <field name="model">item.name</field>
        <field name="arch" type="xml">
            <list string="Item Names">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_item_name_form" model="ir.ui.view">
        <field name="name">item.name.form</field>
        <field name="model">item.name</field>
        <field name="arch" type="xml">
            <form string="Item Name">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_item_name" model="ir.actions.act_window">
        <field name="name">Item Names</field>
        <field name="res_model">item.name</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>