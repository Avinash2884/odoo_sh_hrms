<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_payroll_component_tree" model="ir.ui.view">
        <field name="name">payroll.component.tree</field>
        <field name="model">payroll.component</field>
        <field name="arch" type="xml">
            <list string="Payroll Components">
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_payroll_component_form" model="ir.ui.view">
        <field name="name">payroll.component.form</field>
        <field name="model">payroll.component</field>
        <field name="arch" type="xml">
            <form string="Payroll Component">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_payroll_component" model="ir.actions.act_window">
        <field name="name">Payroll Components</field>
        <field name="res_model">payroll.component</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>