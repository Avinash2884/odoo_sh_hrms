<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_custom_attendance_dashboard" model="ir.actions.act_window">
            <field name="name">Weekly Dashboard</field>
            <field name="res_model">hr.attendance</field>
            <field name="view_mode">pivot,gantt,list,kanban,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No attendance records found yet.
                </p>
            </field>
        </record>

        <menuitem id="menu_custom_attendance_dashboard"
                  name="Weekly Dashboard"
                  parent="hr_attendance.menu_hr_attendance_root"
                  sequence="-1"
                  action="action_custom_attendance_dashboard"/>

        <record id="hr_attendance_view_pivot_custom" model="ir.ui.view">
            <field name="name">hr.attendance.pivot.custom</field>
            <field name="model">hr.attendance</field>
            <field name="inherit_id" ref="hr_attendance.hr_attendance_view_pivot"/>
            <field name="arch" type="xml">
                <xpath expr="//pivot" position="replace">
                    <pivot string="Weekly Attendance Dashboard" sample="1">
                        <field name="employee_id" type="row"/>
                        <field name="check_in" type="row" interval="week"/>

                        <field name="check_in" type="col" interval="month"/>

                        <field name="worked_hours_custom" type="measure" string="Worked Hours"/>
                        <field name="approved_extra_hours" type="measure" string="Approved Extra Hours"/>
                        <field name="total_hours" type="measure" string="Total Hours"/>
                    </pivot>
                </xpath>
            </field>
        </record>
    </data>
</odoo>