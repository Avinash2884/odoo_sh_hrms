<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_attendance_permission_form" model="ir.ui.view">
        <field name="name">hr.attendance.permission.form</field>
        <field name="model">hr.attendance.permission</field>
        <field name="arch" type="xml">
            <form string="Permission Request">
                <header>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight"
                            invisible="state != 'draft'" groups="hr_attendance.group_hr_attendance_manager"/>

                    <button name="action_reject" string="Reject" type="object"
                            invisible="state != 'draft'" groups="hr_attendance.group_hr_attendance_manager"/>

                    <button name="action_cancel" string="Cancel Request" type="object"
                            invisible="state not in ['draft', 'approved', 'rejected']" class="btn btn-secondary"/>

                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'" groups="hr_attendance.group_hr_attendance_manager"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,rejected,cancelled"/>
                </header>
                <sheet>
                    <div class="alert alert-info text-center" role="alert" style="margin-bottom: 20px;">
                        <strong>Permission Policy:</strong>
                        Up to 4 instances of 1-hour permissions per month.
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state != 'draft'" domain="[('user_id', '=', uid)]"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="date" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="occasions_used" readonly="1"/>
                            <field name="reason" readonly="state != 'draft'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_attendance_permission_list" model="ir.ui.view">
        <field name="name">hr.attendance.permission.list</field>
        <field name="model">hr.attendance.permission</field>
        <field name="arch" type="xml">
            <list string="Permission Requests" decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'">
                <field name="date"/>
                <field name="employee_id"/>
                <field name="reason"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'" decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="action_hr_attendance_permission_my" model="ir.actions.act_window">
        <field name="name">My Permission Requests</field>
        <field name="res_model">hr.attendance.permission</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Request your first 1-hour permission.</p>
        </field>
    </record>

    <record id="action_hr_attendance_permission_all" model="ir.actions.act_window">
        <field name="name">Permissions to Approve</field>
        <field name="res_model">hr.attendance.permission</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_draft': 1}</field>
    </record>

    <menuitem id="menu_hr_attendance_permission_user"
              name="My Permissions"
              parent="approvals.approvals_menu_root"
              action="action_hr_attendance_permission_my"
              sequence="10"/>

    <menuitem id="menu_hr_attendance_permission_manager"
              name="All Permissions"
              parent="approvals.approvals_menu_root"
              action="action_hr_attendance_permission_all"
              groups="hr_attendance.group_hr_attendance_manager"
              sequence="20"/>

</odoo>