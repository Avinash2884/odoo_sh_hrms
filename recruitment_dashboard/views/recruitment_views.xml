<odoo>
    <!-- Action for dashboard -->
    <record id="recruitment_dashboard_action" model="ir.actions.client">
        <field name="name">Recruitment Dashboard</field>
        <field name="tag">recruitment_dashboard</field> <!-- matches JS registry key -->
    </record>

    <!-- Menu -->
    <menuitem id="recruitment_menu_dashboard"
              name="Dashboard"
              parent="hr_recruitment.menu_hr_recruitment_root"
              action="recruitment_dashboard_action"
              sequence="-1"/>
</odoo>
