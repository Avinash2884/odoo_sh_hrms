<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== -->
    <!-- list/List View -->
    <!-- ===================== -->
    <record id="view_geo_restriction_list" model="ir.ui.view">
        <field name="name">geo.restriction.list</field>
        <field name="model">geo.restriction</field>
        <field name="arch" type="xml">
            <list string="Geo Restrictions">
                <field name="name"/>
                <field name="company_latitude"/>
                <field name="company_longitude"/>
                <field name="allowed_distance"/>
                <field name="employee_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>


    <!-- ===================== -->
    <!-- Form View -->
    <!-- ===================== -->
    <record id="view_geo_restriction_form" model="ir.ui.view">
        <field name="name">geo.restriction.form</field>
        <field name="model">geo.restriction</field>
        <field name="arch" type="xml">
            <form string="Geo Restriction">
                <sheet>
                    <group>
                        <group string="Office Location">
                            <field name="name"/>
                            <field name="company_latitude"/>
                            <field name="company_longitude"/>
                            <field name="allowed_distance"/>
                            <field name="employee_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <!-- ===================== -->
    <!-- Action -->
    <!-- ===================== -->
    <record id="action_geo_restriction" model="ir.actions.act_window">
        <field name="name">Geo Restriction</field>
        <field name="res_model">geo.restriction</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- ===================== -->
    <!-- Menu -->
    <!-- ===================== -->
    <menuitem
        id="menu_geo_restriction_root"
        name="Geo Restriction"
        parent="hr_attendance.menu_hr_attendance_root"
        sequence="90"/>

    <menuitem
        id="menu_geo_restriction"
        name="Configuration"
        parent="menu_geo_restriction_root"
        action="action_geo_restriction"
        sequence="1"/>

</odoo>