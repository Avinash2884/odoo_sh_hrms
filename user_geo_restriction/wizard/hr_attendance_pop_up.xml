<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attendance_popup_form" model="ir.ui.view">
        <field name="name">attendance.popup.form</field>
        <field name="model">attendance.popup</field>
        <field name="arch" type="xml">
            <form string="Notification">
                <group>
                    <field name="message" readonly="1"/>
                </group>
                <footer>
                    <button string="OK" special="cancel" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>